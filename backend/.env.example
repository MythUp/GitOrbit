# Purpose: Example environment variables for GitHub OAuth capabilities.
# Note: GITHUB_OAUTH_CLIENT_SECRET is optional for Device Flow, required for browser callback flow.
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3547/callback